{
  "info": {
    "_postman_id": "tailor-app-backend-api",
    "name": "Tailor Management Backend API",
    "description": "Complete API collection for Tailor Management SaaS Backend\n\nIMPORTANT:\n1. Import this into Postman\n2. Set Base URL variable\n3. Get JWT token from login endpoint\n4. Use token in other requests\n\nSetup:\n- File > Import > Select this JSON\n- Or paste into Postman directly",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "description": "User authentication endpoints",
      "item": [
        {
          "name": "1. Login / Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"firebase_uid\": \"firebase_uid_demo_123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login or register a user with phone and Firebase UID\n\nAfter OTP verification on frontend:\n- Frontend sends firebase_uid\n- Backend creates user if new\n- Returns JWT token\n\nResponse will contain:\n- user (id, phone, created_at)\n- token (use in Authorization header)"
          },
          "response": []
        },
        {
          "name": "2. Verify Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{jwt_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify-token",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-token"]
            },
            "description": "Verify if a JWT token is valid (public endpoint)"
          },
          "response": []
        },
        {
          "name": "3. Get Auth Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/profile",
              "host": ["{{base_url}}"],
              "path": ["auth", "profile"]
            },
            "description": "Get authenticated user profile (requires JWT token)"
          },
          "response": []
        }
      ]
    },
