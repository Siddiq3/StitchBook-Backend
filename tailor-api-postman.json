                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get all orders for a shop\n\nQuery params:\n- status: pending, stitching, or completed (optional)\n- page: page number\n- limit: records per page"
          },
          "response": []
