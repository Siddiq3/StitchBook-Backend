                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": 1,\n  \"shop_id\": 1,\n  \"description\": \"Shirt stitching with collar\",\n  \"price\": 500,\n  \"delivery_date\": \"2026-04-25\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/order/create",
              "host": ["{{base_url}}"],
              "path": ["order", "create"]
            },
            "description": "Create a new stitching order"
          },
          "response": []
