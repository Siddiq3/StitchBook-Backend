                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/order/shop/1?status=pending&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["order", "shop", "1"],
              "query": [
                {
                  "key": "status",
                  "value": "pending",
                  "disabled": true
