                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Premium Tailor Studio\",\n  \"location\": \"Mumbai, Bandra\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/shop/1",
              "host": ["{{base_url}}"],
              "path": ["shop", "1"]
            },
            "description": "Update shop details"
          },
          "response": []
        }
      ]
