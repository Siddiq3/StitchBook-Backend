# ============================================================================
# STEP 2: ENVIRONMENT CONFIGURATION FILE
# ============================================================================
# This file contains all configuration needed to run the backend
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in each variable with your actual values
# 3. NEVER commit .env file to git
# 4. Keep .env.example for reference (this file)
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# PORT: What port should the server listen on?
# Default: 5000
# For production: Use 3000 or 8000
PORT=5001

# NODE_ENV: Environment mode
# Options: development, production
# Use 'development' during build, 'production' for deployment
NODE_ENV=development

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Choose ONE of these options:
# 
# Option 1: Supabase Connection String (RECOMMENDED - one variable)
# -----------------------------------------------------------------
# Get from: Supabase Dashboard > Settings > Database > Connection String
# Format: postgresql://user:password@host:5432/dbname
# Copy the "PostgreSQL" connection string
# Replace "password" with your database password

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@host:5432/postgres

# 
# Option 2: Individual Database Config (for local PostgreSQL)
# ----------------------------------------------------------
# Uncomment these if using local PostgreSQL instead of Supabase
# 
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=tailor_app
# DB_USER=postgres
# DB_PASSWORD=your_postgres_password

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# REDIS_URL: Redis connection string for session storage, rate limiting, and cache.
# Example: redis://localhost:6379
REDIS_URL=redis-cli --tls -u redis://default:gQAAAAAAAlRaAAIgcDFjNGIzNmM5Y2MzYjU0NjZjYWNkZDdmYTZlMGZkNjkxNA@liked-baboon-152666.upstash.io:6379

# Optional Redis host/port/password override
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# Optional key prefix to namespace all Redis data for this app.
# Useful when sharing Redis with other services.
REDIS_KEY_PREFIX=stitchbook:

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
# JWT_SECRET: Secret key for signing JWT tokens
# ⚠️  IMPORTANT: Change this to a random string in production!
# Generate with: openssl rand -base64 32
# Example: y7kL9mP2qR5xZ8nB3vC6dF1gH4jK5lM9
JWT_SECRET=change_this_to_random_string_in_production_min_32_chars

# JWT_EXPIRY: How long access tokens are valid
# Access tokens should be short-lived in production for better security.
# Recommended values: 15m, 30m, 1h
JWT_EXPIRY=15m

# JWT_REFRESH_SECRET: Secret for refresh tokens (optional)
# Used to issue new access tokens without re-login
JWT_REFRESH_SECRET=change_this_to_random_string_in_production_refresh_min_32_chars

# JWT_REFRESH_EXPIRY: How long refresh tokens are valid
# Usually longer than the access token expiry, but still limited
JWT_REFRESH_EXPIRY=90d

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================
# Primary login: Google Sign-In
# Create OAuth client IDs in Google Cloud Console.
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com

# Secondary login: mobile number through MSG91 OTP Widget
# MSG91_AUTH_KEY is used server-side to verify the widget access token.
# MSG91_WIDGET_ID and MSG91_WIDGET_TOKEN_AUTH are used by the web client.
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_WIDGET_ID=your-msg91-widget-id
MSG91_WIDGET_TOKEN_AUTH=your-msg91-widget-token-auth

# New shops can use the app during this many days before paid subscription is required.
FREE_TRIAL_DAYS=10

# ============================================================================
# LEGACY FIREBASE CONFIGURATION (Kept only for old clients during migration)
# ============================================================================
# Firebase Admin SDK configuration
# 
# FIREBASE_SERVICE_ACCOUNT: Firebase service account JSON (as string)
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# 
# Copy the entire JSON and paste it here (as a stringified JSON)
# Example format:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project",...}
# 
# NOTE: Keep this ABSOLUTELY SECRET! Never share or commit to git.
# In production, use environment variables in your hosting platform.

FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-firebase-project","private_key_id":"key_id","private_key":"-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQE...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"123456789","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk@your-project.iam.gserviceaccount.com"}

# FIREBASE_PROJECT_ID: Your Firebase project ID (for reference)
FIREBASE_PROJECT_ID=your-firebase-project-id

# FIREBASE_API_KEY: Firebase API key (frontend use only)
FIREBASE_API_KEY=your-firebase-api-key

# ============================================================================
# RAZORPAY CONFIGURATION (For Subscription Payments)
# ============================================================================
# Get from: https://dashboard.razorpay.com/app/settings/api-keys
# 
# RAZORPAY_KEY_ID: Your Razorpay Key ID
# RAZORPAY_KEY_SECRET: Your Razorpay Key Secret
# 
# Note: Keep these ABSOLUTELY SECRET!
# Never share or commit to git

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# LOG_LEVEL: How much detail to log?
# Options: error, warn, info, debug
# Development: info (shows important info)
# Production: warn (only warnings and errors)

LOG_LEVEL=info

# ============================================================================
# OPTIONAL: CORS CONFIGURATION
# ============================================================================
# FRONTEND_URL: Where your React Native app is running
# Used to allow requests from specific domains
# For development: http://localhost:3000
# For production: https://yourdomain.com
#
# You can also use a comma-separated list of trusted origins.
# FRONTEND_URLS=http://localhost:3000,https://yourdomain.com

FRONTEND_URL=http://localhost:3000

# ============================================================================
# OPTIONAL: EMAIL CONFIGURATION (For future use)
# ============================================================================
# SMTP_HOST: Email service hostname
# SMTP_USER: Email address
# SMTP_PASS: Email password
# Not needed right now, but here for future use

# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ============================================================================
# STEP-BY-STEP SETUP
# ============================================================================
# 
# 1. Copy this file:
#    cp .env.example .env
# 
# 2. Get DATABASE_URL:
#    - If using Supabase:
#      Go to Supabase Dashboard > Settings > Database > PostgreSQL Connection
#      Copy the "Connection string"
#      Paste it here, replace "password" with your password
#    - If using Local PostgreSQL:
#      Use: postgresql://postgres:your_password@localhost:5432/tailor_app
# 
# 3. Generate JWT_SECRET:
#    Run: openssl rand -base64 32
#    Copy the output and paste here
# 
# 4. Get RAZORPAY Keys (when needed):
#    Go to: https://dashboard.razorpay.com/app/settings/api-keys
#    Get Test Keys first (not Live Keys)
#    Copy Key ID and Key Secret
# 
# 5. Save .env file
# 
# 6. Verify by running:
#    npm run dev
#    If you see "Server running on http://localhost:5000" - SUCCESS!
# 
# ============================================================================
