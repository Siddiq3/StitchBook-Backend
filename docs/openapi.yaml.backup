                  updatedAt: "2026-04-26T10:00:00Z"
        '403':
          description: Forbidden
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Unauthorized access to this order
                error:
                  code: FORBIDDEN
        '404':
          description: Order not found
          content:
            application/json:
              schema:
