        '401':
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Invalid or expired token
                error:
                  code: UNAUTHORIZED

    put:
      tags:
        - Order
      summary: Update order
      description: Updates order details (items, deliveryDate)
      operationId: updateOrder
      security:
        - BearerAuth: []
      parameters:
        - name: id
          in: path
          description: Order ID
          required: true
          schema:
            type: integer
            example: 1
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/OrderUpdateRequest'
            example:
              items:
                - type: "shirt"
                  fabric: "Cotton"
                  quantity: 3
                  price: 500
              deliveryDate: "2026-05-10"
      responses:
        '200':
          description: Order updated successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SuccessResponse'
              example:
                success: true
                message: Order updated successfully
                data:
                  id: 1
                  customerId: 1
                  shopId: 1
                  items:
                    - type: "shirt"
                      fabric: "Cotton"
                      quantity: 3
                      price: 500
                  totalAmount: 1500
                  status: "pending"
                  deliveryDate: "2026-05-10"
                  createdAt: "2026-04-26T10:00:00Z"
                  updatedAt: "2026-04-26T11:00:00Z"
        '403':
          description: Forbidden
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Unauthorized access to this order
                error:
                  code: FORBIDDEN
        '404':
          description: Order not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Order not found
                error:
                  code: ORDER_NOT_FOUND
        '401':
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Invalid or expired token
                error:
                  code: UNAUTHORIZED

    delete:
      tags:
        - Order
      summary: Delete order
      description: Deletes a specific order
      operationId: deleteOrder
      security:
        - BearerAuth: []
      parameters:
        - name: id
          in: path
          description: Order ID
          required: true
          schema:
            type: integer
            example: 1
      responses:
        '200':
          description: Order deleted successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SuccessResponse'
              example:
                success: true
                message: Order deleted successfully
                data: null
        '403':
          description: Forbidden
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Unauthorized access to this order
                error:
                  code: FORBIDDEN
        '404':
          description: Order not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Order not found
                error:
                  code: ORDER_NOT_FOUND
        '401':
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Invalid or expired token
                error:
                  code: UNAUTHORIZED

  /order/{id}/status:
    put:
      tags:
        - Order
      summary: Update order status
      description: |
        Updates order status with flow validation
        
        Valid flow: pending → in_progress → ready → delivered
        Cannot skip stages (e.g., pending → ready is not allowed)
      operationId: updateOrderStatus
      security:
        - BearerAuth: []
      parameters:
        - name: id
          in: path
          description: Order ID
          required: true
          schema:
            type: integer
            example: 1
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/OrderStatusRequest'
            example:
              status: "in_progress"
      responses:
        '200':
          description: Order status updated successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SuccessResponse'
              example:
                success: true
                message: Order status updated successfully
                data:
                  id: 1
                  customerId: 1
                  shopId: 1
                  items:
                    - type: "shirt"
                      fabric: "Cotton"
                      quantity: 2
                      price: 500
                  totalAmount: 1000
                  status: "in_progress"
                  deliveryDate: "2026-05-01"
                  createdAt: "2026-04-26T10:00:00Z"
                  updatedAt: "2026-04-26T11:00:00Z"
        '400':
          description: Invalid status transition
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: "Invalid status transition from 'pending' to 'delivered'. Allowed: in_progress"
                error:
                  code: INVALID_STATUS_TRANSITION
        '403':
          description: Forbidden
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Unauthorized access to this order
                error:
                  code: FORBIDDEN
        '404':
          description: Order not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Order not found
                error:
                  code: ORDER_NOT_FOUND
        '401':
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Invalid or expired token
                error:
                  code: UNAUTHORIZED

  # ==================== MEASUREMENT ====================

  /measurement:
    post:
      tags:
        - Measurement
      summary: Create a new measurement
      description: |
        Creates measurement with dynamic fields
        
        Any field names can be used (chest, waist, length, sleeve, etc.)
        Data is stored as JSONB for flexibility
      operationId: createMeasurement
      security:
        - BearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/MeasurementRequest'
            example:
              customerId: 1
              measurementsData:
                chest: 40
                waist: 32
                length: 28
                sleeve: 24
                neck: 15
                shoulder: 18
      responses:
        '201':
          description: Measurement created successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SuccessResponse'
              example:
                success: true
                message: Measurement created successfully
                data:
                  id: 1
                  customerId: 1
                  measurementsData:
                    chest: 40
                    waist: 32
                    length: 28
                    sleeve: 24
                    neck: 15
                    shoulder: 18
                  createdAt: "2026-04-26T10:00:00Z"
                  updatedAt: "2026-04-26T10:00:00Z"
        '400':
          description: Invalid request
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Customer ID and measurements data are required
                error:
                  code: INVALID_INPUT
        '403':
          description: Forbidden
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Unauthorized access to this customer
                error:
                  code: FORBIDDEN
        '401':
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                success: false
                message: Invalid or expired token
                error:
                  code: UNAUTHORIZED

